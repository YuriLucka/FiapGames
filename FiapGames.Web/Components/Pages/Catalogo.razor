@page "/"
@using FiapGames.Web.Components.Shared;

<PageTitle>Catálogo</PageTitle>

<div class="header-page">
    <h1>Catálogo</h1>
    <SearchBar OnSearch="HandleSearch" Placeholder="Buscar jogo" />
</div>

<GameFilters Categorias="@categorias"
             Desenvolvedores="@desenvolvedores"
             OnFilterChanged="HandleFilterChanged" />

<div class="row g-3">
    @foreach (var jogo in jogos)
    {
        <div class="col-3">
            <GameCard Title="@jogo.Title"
                      Price="@jogo.Price"
                      ImageUrl="@jogo.ImageUrl" />
        </div>
    }
</div>

@code {
    private List<string> categorias = ["Ação", "RPG", "Estratégia"];
    private List<string> desenvolvedores = ["CD Projekt", "Valve", "Ubisoft"];

    private void HandleFilterChanged(GameFilterValues filtros)
    {
    }

    private void HandleSearch(string termo)
    {
    }

    private List<(string Title, string Price, string ImageUrl)> jogos =
    [
        ("Elden Ring", "R$ 199,99", "/images/capaJogos/elden-ring.jpg"),
        ("God of War", "R$ 149,99", "/images/capaJogos/gow.jpg"),
        ("Cyberpunk 2077", "R$ 99,99", "/images/capaJogos/cyberpunk.jpg"),
        ("The Witcher 3", "R$ 49,99", "/images/capaJogos/witcher.jpg")
    ];
}